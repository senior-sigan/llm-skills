{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ruff_format.py \"$CLAUDE_PROJECT_DIR\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ruff_validator.py \"$CLAUDE_PROJECT_DIR\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ty_validator.py \"$CLAUDE_PROJECT_DIR\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
